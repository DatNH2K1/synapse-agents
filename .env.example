# ============================================================================
# Synapse Global Environment Configuration (Template)
# ============================================================================
SYNAPSE_PORTAL_HOST=http://localhost:3100
SYNAPSE_PORTAL_PORT=3100
SYNAPSE_DB_PORT=5000

# --- [1] AI Provider Configuration ---
# Required for brain functions, vector similarity, and agentic skills.
# Get your Gemini API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- [2] Database Connection ---
# Configuration for PostgreSQL with pgvector support.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse

# --- [4] Synapse Framework & Agentic Skills ---
# Keys for extended agent capabilities and research tools.
CONTEXT7_API_KEY=
STITCH_API_KEY=

# --- [5] Agent & Experience Configuration ---
SYNAPSE_USER_NAME=User
SYNAPSE_COMMUNICATION_LANGUAGE=English
SYNAPSE_DOCUMENT_OUTPUT_LANGUAGE=Vietnamese
