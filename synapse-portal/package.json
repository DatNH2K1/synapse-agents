{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "npx prisma db seed",
    "prebuild": "npx prisma generate",
    "test": "vitest run",
    "test:silent": "vitest run --silent",
    "prettier": "npx prettier --write .",
    "check:lint": "eslint .",
    "check:types": "tsc --noEmit",
    "check:deps": "knip",
    "check:i18n": "i18n-check -s en --locales locales/ -f i18next",
    "check": "npm run check:lint && npm run check:types && npm run check:deps && npm run check:i18n",
    "check:fix": "npm run prettier && npm run check"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "knip": "^6.15.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@lingual/i18n-check": "^0.9.5",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-i18next": "^6.1.4",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
